<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
    <!--
    This file contains suppressions for known false positives in OWASP Dependency Check.
    Only add suppressions for verified false positives after careful analysis.

    Example suppression:
    <suppress>
        <notes><![CDATA[
        Explanation of why this is a false positive
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/com\.example/.*@.*$</packageUrl>
        <cve>CVE-2023-12345</cve>
    </suppress>
    -->

    <!-- Suppress false positives for Android SDK and common libraries -->
    <suppress>
        <notes><![CDATA[
        Android SDK components are managed by Google and updated through Android Studio.
        These are not typical web application dependencies and follow Android's security model.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/com\.android\..*@.*$</packageUrl>
    </suppress>

    <suppress>
        <notes><![CDATA[
        Jetpack Compose BOM manages all Compose library versions and is regularly updated by Google.
        Security issues in Compose are handled through BOM updates.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/androidx\.compose/.*@.*$</packageUrl>
    </suppress>

    <!-- Add specific suppressions here as needed -->

</suppressions>